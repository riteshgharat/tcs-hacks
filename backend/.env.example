# --- Backend ---
BACKEND_PORT=8787
DB_PATH=./data/guardrail.sqlite
CORS_ORIGINS=http://localhost:5173,chrome-extension://*

# --- LLM (OpenAI-compatible; defaults to Vultr Inference) ---
# For Vultr: set LLM_BASE_URL=https://api.vultrinference.com/v1
# For OpenAI: set LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://api.vultrinference.com/v1
LLM_API_KEY=sk-vultr-...             # Your Vultr API key; leave empty to run rules-only fallback
LLM_MODEL=llama-3.1-8b-instruct      # or any model available on your Vultr endpoint
LLM_TIMEOUT_MS=15000
LLM_MAX_RETRIES=2
# Some inference providers (including Vultr) do not support response_format.
# Set to true only if the provider supports structured-JSON / json_object mode.
LLM_USE_JSON_MODE=false

# --- Engine ---
ENGINE_VERSION=1.0.0
DEFAULT_RULE_LANG=en-v1
MAX_INPUT_CHARS=16000
